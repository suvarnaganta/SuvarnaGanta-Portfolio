<script>
  // ---- Theme toggle (in-memory only, no storage APIs) ----
  const root = document.documentElement;
  const themeBtn = document.getElementById('themeToggle');
  const iconMoon = document.getElementById('iconMoon');
  const iconSun = document.getElementById('iconSun');
  function setTheme(theme){
    root.setAttribute('data-theme', theme);
    if(theme === 'dark'){ iconMoon.style.display='block'; iconSun.style.display='none'; }
    else { iconMoon.style.display='none'; iconSun.style.display='block'; }
  }
  setTheme('dark');
  themeBtn.addEventListener('click', () => {
    const current = root.getAttribute('data-theme');
    setTheme(current === 'dark' ? 'light' : 'dark');
  });

  // ---- Hero translator widget ----
  const pairs = [
    {
      left: "Customers can't tell if their order shipped.",
      right: "As a customer, I want real-time order status on my account page, so I know when to expect delivery. AC: status updates within 5 min of carrier scan, visible on mobile and desktop."
    },
    {
      left: "Support is flooded with 'where's my digital pack' tickets.",
      right: "As a collector, I want a delivery confirmation for digital packs, so I don't need to contact support. AC: push and email confirmation sent on mint completion, visible in order history."
    },
    {
      left: "We're losing carts at checkout on mobile.",
      right: "As a shopper, I want a single-page mobile checkout, so I can complete a purchase in fewer taps. AC: form validates inline; an error never clears fields already entered."
    }
  ];
  const tLeft = document.getElementById('tLeft');
  const tRight = document.getElementById('tRight');
  const tDots = document.getElementById('tDots');
  pairs.forEach((_, i) => {
    const d = document.createElement('span');
    if(i === 0) d.classList.add('active');
    tDots.appendChild(d);
  });
  let idx = 0;
  function renderPair(i){
    tLeft.style.opacity = 0;
    tRight.style.opacity = 0;
    setTimeout(() => {
      tLeft.textContent = pairs[i].left;
      tRight.textContent = pairs[i].right;
      tLeft.style.transition = 'opacity .4s ease';
      tRight.style.transition = 'opacity .4s ease';
      tLeft.style.opacity = 1;
      tRight.style.opacity = 1;
    }, 250);
    [...tDots.children].forEach((d, di) => d.classList.toggle('active', di === i));
  }
  renderPair(0);
  setInterval(() => {
    idx = (idx + 1) % pairs.length;
    renderPair(idx);
  }, 5000);

  // ---- Scroll reveal ----
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if(entry.isIntersecting){
        entry.target.classList.add('in');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

